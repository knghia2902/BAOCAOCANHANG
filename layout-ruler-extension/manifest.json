{
  "manifest_version": 3,
  "name": "Thước Đo Thiết Kế (Layout Ruler)",
  "version": "1.0.0",
  "description": "Thước đo thiết kế tạm thời dùng để soi chi tiết layout (hover), hiện khung viền và lưới 12 cột.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Bật/Tắt Thước Đo Thiết Kế"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
